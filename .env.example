# Global runtime mode
ENV=dev
LOG_LEVEL=INFO

# Backend binding (production should keep localhost unless reverse-proxied)
BACKEND_BIND_ALL_INTERFACES=0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Restrict browser/webview origins that may call backend APIs
CORS_ALLOWED_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost
ALLOWED_WS_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost

# Public frontend endpoints (non-secret)
PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_WS_BASE_URL=ws://localhost:8000

# Providers (keep blank if unused)
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

TTS_PROVIDER=auto
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

WEB_SEARCH_PROVIDER=none
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
