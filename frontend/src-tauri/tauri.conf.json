{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SarahNode",
  "version": "0.3.0",
  "identifier": "com.sarahnode.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 5173",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SarahNode",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "maximized": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "visible": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
